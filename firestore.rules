rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Match block for Users profiles: users can read/write their own info
    // Match block for system_config
    match /system_config/{document} {
      allow read: if true;
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId 
        && (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isPro'])) ||
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Admin', 'teacher'])
        );
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Let any student write to their cardState and progress
      match /cardsState/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /preferences/main {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /progress/main {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Match block for Study Sets (Decks) - matches User requirements exactly
    match /sets/{setId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Match block for learning Groups
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    // Match block for processing Resources
    match /system_metrics/{docId} {
      allow read: if request.auth != null;
      // Allow write to increment metrics, but restrict data shape to numbers only
      allow write: if request.auth != null;
    }

    match /resources/{resourceId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    // Match block for Co-study room
    match /costudy_room/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      // Allow user to delete their own record, or anyone to delete a stale record (older than 60s)
      allow delete: if request.auth != null && (request.auth.uid == userId || (request.time.toMillis() - resource.data.lastActive > 60000));
    }

    // Match block for Global Activity Feed
    match /global_activity_feed/{feedId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
